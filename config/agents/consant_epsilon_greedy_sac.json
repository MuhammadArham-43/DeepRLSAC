{
    "agent_name": "EpsilonGreedySAC",
    "parameters":
    {
	"replay_capacity": 1000000,
	"batch_size": 256,
	"tau": 0.005,
    "gamma": 0.99,
	"betas": [0.9, 0.999],
	"target_update_interval": 1,
	"critic_lr": 3e-4,
	"actor_lr": 3e-4,
    "auto_entropy_tuning": false,
    "alpha": 0.2,
	"actor_hidden_dim": 256,
	"critic_hidden_dim": 256,
	"init": "xavier_uniform",
	"clip_stddev": 1000,
	"cuda": true,
	"epsilon_schedule": {
            "type": "Constant",
            "value": 0.1
        }
    }
}